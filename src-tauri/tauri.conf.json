{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GitPulse",
  "version": "0.1.0",
  "identifier": "com.gitpulse.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "GitPulse",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
